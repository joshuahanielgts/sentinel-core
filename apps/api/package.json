{
    "name": "sentinel-api",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev -p 3001",
        "dev:clean": "node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true }); console.log('Removed apps/api/.next cache')\"",
        "dev:fresh": "npm run dev:clean && npm run dev",
        "build": "next build",
        "start": "next start -p 3001",
        "lint": "next lint",
        "deploy": "cd ../.. && npx vercel deploy --prod --yes",
        "deploy:preview": "cd ../.. && npx vercel deploy --yes"
    },
    "dependencies": {
        "@google/generative-ai": "^0.24.0",
        "@supabase/supabase-js": "^2.102.1",
        "mammoth": "^1.12.0",
        "next": "^15.3.1",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "zod": "^3.24.3"
    },
    "devDependencies": {
        "@types/node": "^22.14.1",
        "@types/react": "^19.1.0",
        "typescript": "^5.8.3"
    }
}
